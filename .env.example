# Telegram Bot Token from @BotFather
TG_TOKEN=your_telegram_bot_token_here

# Matrix Synapse server URL
MATRIX_HOMESERVER=https://matrix.org

# Matrix username (e.g. @bridge:matrix.org)
MATRIX_USER=@bridge:matrix.org

# Matrix password
MATRIX_PASSWORD=your_matrix_password_here

# Microsoft Teams OAuth2 credentials
TEAMS_TENANT_ID=your_tenant_id_here
TEAMS_CLIENT_ID=your_client_id_here
TEAMS_CLIENT_SECRET=your_client_secret_here

# HTTP API port
API_PORT=8000

# Secret token for external API calls
API_TOKEN=secret-bridge-token