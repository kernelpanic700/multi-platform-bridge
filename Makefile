'".PHONY: help install test lint run docker-build docker-up docker-down clean\n\nhelp:\n\t@echo \"Available commands:\"\n\t@echo \"  make install        - Install Python dependencies\"\n\t@echo \"  make test           - Run unit tests\"\n\t@echo \"  make lint           - Run linters\"\n\t@echo \"  make run            - Run bridge bot locally\"\n\t@echo \"  make docker-build   - Build Docker image\"\n\t@echo \"  make docker-up      - Start Docker Compose stack\"\n\t@echo \"  make docker-down    - Stop Docker Compose stack\"\n\t@echo \"  make clean          - Clean Python cache and temp files\"\n\ninstall:\n\tpip install -r requirements.txt\n\ntest:\n\tpython -m pytest tests/ -v\n\nlint:\n\tpython -m ruff check src/ tests/\n\tpython -m black --check src/ tests/\n\nrun:\n\tpython src/main.py\n\ndocker-build:\n\tdocker build -t bridge-bot .\n\ndocker-up:\n\tdocker-compose up -d\n\ndocker-down:\n\tdocker-compose down\n\nclean:\n\tfind . -type f -name '\''*.pyc'\'' -delete\n\tfind . -type d -name '\''__pycache__'\'' -delete\n\tfind . -type d -name '\''.pytest_cache'\'' -exec rm -rf {} +\n\trm -rf /tmp/bridge_bot"'